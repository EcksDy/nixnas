#!/usr/bin/env bash
# =============================================================================
# nixnas-status -- NixNAS Live Dashboard v4 (media-stack edition)
# =============================================================================
# Usage : sudo nixnas-status          (default 5s refresh)
#         sudo nixnas-status -r 3      (custom refresh)
#         sudo nixnas-status --once    (render once, no loop)
#
# Topology: 1x NVMe (OS+apps) + 1x HDD (media, btrfs). No RAID, no NFS.
# Adds a CONTAINERS panel (media stack) and VPN status.
# =============================================================================

set -euo pipefail

REFRESH=5
ONCE=false
while [[ $# -gt 0 ]]; do
    case "$1" in
        -r|--refresh) REFRESH="$2"; shift 2 ;;
        --once)       ONCE=true; shift ;;
        *)            shift ;;
    esac
done

# Auto-detect the active default-route interface + gateway (DHCP; not hardcoded).
IFACE="$(ip -o route show default 2>/dev/null | awk '{print $5; exit}')"
[ -z "$IFACE" ] && IFACE="$(ip -o -4 addr show scope global 2>/dev/null | awk '{print $2; exit}')"
[ -z "$IFACE" ] && IFACE="unknown"
GATEWAY="$(ip -o route show default 2>/dev/null | awk '{print $3; exit}')"
[ -z "$GATEWAY" ] && GATEWAY="n/a"
DNS_SERVER="$(awk '/^nameserver/{print $2; exit}' /etc/resolv.conf 2>/dev/null)"
[ -z "$DNS_SERVER" ] && DNS_SERVER="n/a"

HDD_DRIVES=("sda")
HDD_LABEL=("WD Purple")
NVME_DRIVES=("nvme0n1")
NVME_LABEL=("ADATA 900")

# Detect UGOS SSD device (serial-matched; device node may shift)
UGOS_SERIAL="nvme-YSO128GTLCW-E3C-2_511250811096010990"
UGOS_DEV=""
for candidate in nvme1n1 nvme2n1 nvme3n1; do
    if [[ -e "/dev/$candidate" ]] && readlink -f "/dev/disk/by-id/${UGOS_SERIAL}" 2>/dev/null | grep -q "$candidate"; then
        UGOS_DEV="$candidate"; break
    fi
done

SERVICES=("sshd" "docker" "smartd" "ugos-protect" "fail2ban" "fan-control" "tailscaled" "traefik")
SVC_SHORT=("sshd" "docker" "smartd" "ugos"         "f2ban"   "fans"        "tscale"     "traefik")

# Media stack containers to show (name:label)
CONTAINERS=("gluetun" "qbittorrent" "sabnzbd" "prowlarr" "sonarr" "sonarr-anime" "radarr" "bazarr" "jellyfin" "seerr")

NIXOS_CONFIG="/etc/nixos"

# =============================================================================
# COLORS
# =============================================================================
if [[ -t 1 ]]; then
    RST="\e[0m"; BLD="\e[1m"; DIM="\e[2m"
    GRN="\e[32m"; YLW="\e[33m"; RED="\e[31m"; CYN="\e[36m"
    BGRN="\e[1;32m"; BYLW="\e[1;33m"; BRED="\e[1;31m"; BCYN="\e[1;36m"; BWHT="\e[1;37m"
else
    RST="" BLD="" DIM="" GRN="" YLW="" RED="" CYN=""
    BGRN="" BYLW="" BRED="" BCYN="" BWHT=""
fi

# =============================================================================
# HELPERS
# =============================================================================
W=80
hr()  { printf "  ${DIM}"; printf '─%.0s' $(seq 1 $((W-4))); printf "${RST}\n"; }
hdr() { printf "  ${BCYN}━━ %s${RST}\n" "$1"; }
dot() { case "$1" in active|PASSED|clean*|running|healthy) printf "${BGRN}●${RST}" ;; degraded*|starting|unhealthy) printf "${BYLW}●${RST}" ;; *) printf "${BRED}●${RST}" ;; esac; }

bar() {
    local used=${1:-0} total=${2:-1} width=${3:-20}
    local pct=0
    (( total > 0 )) && pct=$(( used * 100 / total ))
    local filled=$(( pct * width / 100 ))
    local empty=$(( width - filled ))
    local color="$GRN"
    (( pct > 80 )) && color="$YLW"
    (( pct > 95 )) && color="$RED"
    printf "${color}"
    printf '█%.0s' $(seq 1 $filled) 2>/dev/null || true
    printf "${DIM}"
    printf '░%.0s' $(seq 1 $empty) 2>/dev/null || true
    printf "${RST} %3d%%" "$pct"
}

fmt() {
    local b=${1:-0}
    (( b == 0 )) && { echo "0 B"; return; }
    if   (( b >= 1099511627776 )); then printf "%.2f TiB" "$(echo "scale=2; $b/1099511627776" | bc)"
    elif (( b >=    1073741824 )); then printf "%.1f GiB" "$(echo "scale=1; $b/1073741824"    | bc)"
    elif (( b >=       1048576 )); then printf "%.1f MiB" "$(echo "scale=1; $b/1048576"       | bc)"
    else                               printf "%d KiB"    "$(( b / 1024 ))"
    fi
}
fmtr() { local v="$1"; [[ "$v" == .* ]] && echo "0${v}" || echo "$v"; }

blk_stat() {
    local f="/sys/block/$1/stat"
    [[ -f "$f" ]] || { echo "0 0"; return; }
    local r w; read -r _ _ r _ _ _ w _ _ _ _ < "$f"
    echo $(( r * 512 )) $(( w * 512 ))
}

collect_io() {
    declare -gA IO_R IO_W
    local -A s_r s_w
    local all_drives=("${HDD_DRIVES[@]}" "${NVME_DRIVES[@]}")
    [[ -n "$UGOS_DEV" ]] && all_drives+=("$UGOS_DEV")
    for d in "${all_drives[@]}"; do
        read -r r w <<< "$(blk_stat "$d")"; s_r[$d]=$r; s_w[$d]=$w
    done
    local rx0 tx0
    rx0=$(cat "/sys/class/net/${IFACE}/statistics/rx_bytes" 2>/dev/null || echo 0)
    tx0=$(cat "/sys/class/net/${IFACE}/statistics/tx_bytes" 2>/dev/null || echo 0)
    local snap0; snap0=$(awk '/^cpu /{print $2,$3,$4,$5,$6,$7,$8}' /proc/stat)
    sleep 1
    for d in "${all_drives[@]}"; do
        read -r r w <<< "$(blk_stat "$d")"
        IO_R[$d]=$(echo "scale=1; ($r-${s_r[$d]})/1048576" | bc)
        IO_W[$d]=$(echo "scale=1; ($w-${s_w[$d]})/1048576" | bc)
    done
    local rx1 tx1
    rx1=$(cat "/sys/class/net/${IFACE}/statistics/rx_bytes" 2>/dev/null || echo 0)
    tx1=$(cat "/sys/class/net/${IFACE}/statistics/tx_bytes" 2>/dev/null || echo 0)
    NET_RX=$(echo "scale=1; ($rx1-$rx0)/1048576" | bc)
    NET_TX=$(echo "scale=1; ($tx1-$tx0)/1048576" | bc)
    local snap1; snap1=$(awk '/^cpu /{print $2,$3,$4,$5,$6,$7,$8}' /proc/stat)
    CPU_PCT=$(awk -v s0="$snap0" -v s1="$snap1" 'BEGIN {
        split(s0,a); split(s1,b)
        dt=(b[1]+b[2]+b[3]+b[4]+b[5]+b[6]+b[7])-(a[1]+a[2]+a[3]+a[4]+a[5]+a[6]+a[7])
        di=b[4]-a[4]; printf "%d", (dt>0) ? (dt-di)*100/dt : 0 }')
}

sh() { smartctl -H "/dev/$1" 2>/dev/null | awk '/result:/{print $NF}' | head -1 || true; }
ht() { smartctl -A "/dev/$1" 2>/dev/null | awk '$1==194||$1==190{print $10; exit}' || true; }
nt() { smartctl -A "/dev/$1" 2>/dev/null | awk '/^Temperature:/{print $2; exit}' || true; }
hh() { smartctl -A "/dev/$1" 2>/dev/null | awk '$1==9{print $10; exit}' || true; }
nh() { smartctl -A "/dev/$1" 2>/dev/null | awk '/Power On Hours/{gsub(/,/,"",$4); print $4; exit}' || true; }

# container state: running/exited/... via docker; "n/a" if docker absent
cstate() { docker inspect -f '{{.State.Status}}' "$1" 2>/dev/null || echo "absent"; }
# container health if defined
chealth() { docker inspect -f '{{if .State.Health}}{{.State.Health.Status}}{{end}}' "$1" 2>/dev/null || true; }

# =============================================================================
# RENDER
# =============================================================================
render() {
    local now hn uptime_str kernel gen rebuild_date flake_age
    now=$(date "+%Y-%m-%d  %H:%M:%S")
    hn=$(hostname)
    uptime_str=$(awk '{s=$1; d=int(s/86400); h=int((s%86400)/3600); m=int((s%3600)/60)
        if (d>0) printf "%dd %dh %02dm", d, h, m; else printf "%dh %02dm", h, m}' /proc/uptime)
    kernel=$(uname -r)
    gen=$(readlink /nix/var/nix/profiles/system 2>/dev/null | grep -oP '\d+' | tail -1 || echo "?")
    rebuild_date=$(stat -c "%y" /nix/var/nix/profiles/system 2>/dev/null | cut -c1-10 || echo "?")
    local flake_lock="${NIXOS_CONFIG}/flake.lock"
    if [[ -f "$flake_lock" ]]; then
        flake_age=$(( ( $(date +%s) - $(stat -c "%Y" "$flake_lock") ) / 86400 ))
    else flake_age="?"; fi

    local ram_used ram_total ram_pct
    read -r ram_used ram_total ram_pct <<< "$(awk '/MemTotal/{t=$2} /MemAvailable/{a=$2}
        END{printf "%.1f %.1f %d",(t-a)/1048576,t/1048576,(t-a)*100/t}' /proc/meminfo)"
    local load1 load5 load15; read -r load1 load5 load15 _ _ <<< "$(cat /proc/loadavg)"

    local ip link_speed ping_gw ping_dns
    ip=$(ip -4 addr show "$IFACE" 2>/dev/null | awk '/inet /{print $2}')
    link_speed=$(cat "/sys/class/net/${IFACE}/speed" 2>/dev/null || echo "?")
    ping_gw=$(ping -c1 -W1 "$GATEWAY" 2>/dev/null | awk -F/ '/avg/{printf "%.1f",$5}' || echo "---")
    ping_dns=$(ping -c1 -W1 "$DNS_SERVER" 2>/dev/null | awk -F/ '/avg/{printf "%.1f",$5}' || echo "---")

    # Tailscale
    local ts_ip=""
    ts_ip=$(tailscale ip -4 2>/dev/null | head -1 || true)

    # Storage
    local d_total=0 d_used=0 d_free=0 r_total r_used r_free a_total a_used a_free
    local btrfs_out; btrfs_out=$(btrfs filesystem usage -b /data 2>/dev/null) || true
    if [[ -n "$btrfs_out" ]]; then
        d_total=$(echo "$btrfs_out" | awk '/Device size:/{print $NF}')
        d_used=$(echo "$btrfs_out" | awk '/^[[:space:]]+Used:/{print $NF}')
        d_free=$(echo "$btrfs_out" | awk '/Free \(statfs/{print $NF}')
    fi
    r_total=$(df -B1 / 2>/dev/null | awk 'NR==2{print $2}')
    r_used=$(df -B1 / 2>/dev/null | awk 'NR==2{print $3}')
    r_free=$(df -B1 / 2>/dev/null | awk 'NR==2{print $4}')
    a_total=$(df -B1 /apps 2>/dev/null | awk 'NR==2{print $2}')
    a_used=$(df -B1 /apps 2>/dev/null | awk 'NR==2{print $3}')
    a_free=$(df -B1 /apps 2>/dev/null | awk 'NR==2{print $4}')

    # VPN (gluetun): egress IP + forwarded port
    local vpn_ip="" vpn_port=""
    if [[ "$(cstate gluetun)" == "running" ]]; then
        vpn_ip=$(docker exec gluetun wget -qO- -T2 https://ipinfo.io/ip 2>/dev/null | head -1 || true)
        vpn_port=$(docker logs --tail 200 gluetun 2>/dev/null | grep -oiE 'port forwarded is [0-9]+' | tail -1 | grep -oE '[0-9]+' || true)
    fi

    # ── OUTPUT ───────────────────────────────────────────────────────────────
    if $ONCE; then clear; else tput cup 0 0 2>/dev/null || clear; fi

    local pad=$(( W - 16 - ${#hn} - ${#now} ))
    (( pad < 1 )) && pad=1
    printf "  ${BWHT}NIXNAS${RST} ${DIM}//${RST} ${BLD}%s${RST}%*s${DIM}%s${RST}\n" "$hn" "$pad" "" "$now"
    hr

    # SYSTEM
    hdr "SYSTEM"
    printf "  CPU ${BLD}%s${RST}  ${DIM}│${RST}  Load: %s %s %s  ${DIM}│${RST}  Uptime: %s  ${DIM}│${RST}  Kernel: %s\n" \
        "${CPU_PCT}%" "$load1" "$load5" "$load15" "$uptime_str" "$kernel"
    printf "  Mem ${BLD}%s${RST}/%s GiB  " "$ram_used" "$ram_total"
    bar "$(echo "$ram_used * 1073741824 / 1" | bc)" "$(echo "$ram_total * 1073741824 / 1" | bc)" 20
    printf "  ${DIM}│${RST}  Gen #%s ${DIM}(%s)${RST}" "$gen" "$rebuild_date"
    if [[ "$flake_age" != "?" ]] && (( flake_age >= 14 )); then
        printf "  ${BYLW}⚠ %sd old${RST}" "$flake_age"
    elif [[ "$flake_age" != "?" ]]; then
        printf "  ${GRN}✓${RST}"
    fi
    printf "\n"

    # NETWORK
    printf "\n"
    printf "  ${BCYN}━━ NETWORK${RST}  ${DIM}(%s)${RST}\n" "$IFACE"
    printf "  IP ${BLD}%-18s${RST} Link ${BLD}%s${RST}Mb/s  RX ${BCYN}%s${RST} TX ${BCYN}%s${RST}MB/s  Ping ${BLD}%s${RST}/${BLD}%s${RST}ms\n" \
        "${ip:--}" "$link_speed" "$(fmtr "$NET_RX")" "$(fmtr "$NET_TX")" "$ping_gw" "$ping_dns"
    printf "  Tailscale ${BLD}%s${RST}   VPN egress ${BLD}%s${RST}   fwd port ${BLD}%s${RST}\n" \
        "${ts_ip:--}" "${vpn_ip:--}" "${vpn_port:--}"

    # STORAGE
    printf "\n"
    hdr "STORAGE"
    printf "  ${BLD}/data${RST} $(fmt "${d_total:-0}") "
    bar "${d_used:-0}" "${d_total:-1}" 22
    printf " Used ${BLD}$(fmt "${d_used:-0}")${RST} Free ${BGRN}$(fmt "${d_free:-0}")${RST}\n"
    printf "  ${BLD}/apps${RST} $(fmt "${a_total:-0}") "
    bar "${a_used:-0}" "${a_total:-1}" 22
    printf " Used ${BLD}$(fmt "${a_used:-0}")${RST} Free ${BGRN}$(fmt "${a_free:-0}")${RST}\n"
    printf "  ${BLD}/${RST}     $(fmt "${r_total:-0}") "
    bar "${r_used:-0}" "${r_total:-1}" 22
    printf " Used ${BLD}$(fmt "${r_used:-0}")${RST} Free ${BGRN}$(fmt "${r_free:-0}")${RST}\n"

    # DRIVES
    printf "\n"
    hdr "DRIVES"
    printf "  ${DIM}%-10s %-10s %-6s %-5s %6s  %8s  %8s${RST}\n" \
        "Device" "Label" "Health" "Temp" "Hours" "Read" "Write"
    hr
    for i in "${!HDD_DRIVES[@]}"; do
        local d="${HDD_DRIVES[$i]}" h t hrs
        h=$(sh "$d"); t=$(ht "$d"); hrs=$(hh "$d")
        local tc="$GRN"; [[ -n "$t" ]] && (( t >= 45 )) && tc="$YLW"; [[ -n "$t" ]] && (( t >= 55 )) && tc="$RED"
        printf "  $(dot "${h:-?}") %-9s %-10s %-6s ${tc}%-5s${RST} %6s  %6s MB/s  %6s MB/s\n" \
            "$d" "${HDD_LABEL[$i]}" "${h:-?}" "${t:--}°C" "${hrs:--}h" \
            "$(fmtr "${IO_R[$d]:-0}")" "$(fmtr "${IO_W[$d]:-0}")"
    done
    for i in "${!NVME_DRIVES[@]}"; do
        local d="${NVME_DRIVES[$i]}" h t hrs
        h=$(sh "$d"); t=$(nt "$d"); hrs=$(nh "$d")
        local tc="$GRN"; [[ -n "$t" ]] && (( t >= 50 )) && tc="$YLW"; [[ -n "$t" ]] && (( t >= 70 )) && tc="$RED"
        printf "  $(dot "${h:-?}") %-9s %-10s %-6s ${tc}%-5s${RST} %6s  %6s MB/s  %6s MB/s\n" \
            "$d" "${NVME_LABEL[$i]}" "${h:-?}" "${t:--}°C" "${hrs:--}h" \
            "$(fmtr "${IO_R[$d]:-0}")" "$(fmtr "${IO_W[$d]:-0}")"
    done
    if [[ -n "$UGOS_DEV" ]]; then
        local h t hrs; h=$(sh "$UGOS_DEV"); t=$(nt "$UGOS_DEV"); hrs=$(nh "$UGOS_DEV")
        local ro; ro=$(blockdev --getro "/dev/$UGOS_DEV" 2>/dev/null || echo "?")
        local tag; [[ "$ro" == "1" ]] && tag="${BGRN}read-only${RST}" || tag="${BRED}WRITABLE!${RST}"
        printf "  $(dot "${h:-?}") %-9s %-10s %-6s %-5s %6s  %b\n" \
            "$UGOS_DEV" "UGOS" "${h:-?}" "${t:--}°C" "${hrs:--}h" "$tag"
    fi

    # CONTAINERS
    printf "\n"
    hdr "CONTAINERS"
    local col=0
    for c in "${CONTAINERS[@]}"; do
        local st hl show
        st=$(cstate "$c")
        hl=$(chealth "$c")
        show="$st"; [[ -n "$hl" ]] && show="$hl"
        printf "  $(dot "$show") %-13s" "$c"
        col=$(( col + 1 ))
        (( col % 3 == 0 )) && printf "\n"
    done
    (( col % 3 != 0 )) && printf "\n"

    # SERVICES
    printf "\n"
    printf "  ${BCYN}━━ SERVICES${RST}  "
    for i in "${!SERVICES[@]}"; do
        local st; st=$(systemctl is-active "${SERVICES[$i]}" 2>/dev/null || echo "inactive")
        printf "$(dot "$st") %-7s " "${SVC_SHORT[$i]}"
        (( (i+1) % 4 == 0 )) && printf "\n                "
    done
    printf "\n"

    # FOOTER
    printf "\n"
    hr
    printf "  ${DIM}NixNAS v4  │  Refresh: %ss  │  Ctrl+C to exit${RST}\n" "$REFRESH"
}

# =============================================================================
# MAIN
# =============================================================================
[[ $EUID -ne 0 ]] && { echo "Run as root: sudo nixnas-status"; exit 1; }

declare -A IO_R IO_W
NET_RX="0.0"; NET_TX="0.0"; CPU_PCT=0

if $ONCE; then
    collect_io; render; exit 0
fi

tput civis 2>/dev/null
trap 'tput cnorm 2>/dev/null; exit' EXIT INT TERM

while true; do
    collect_io; render
    sleep $(( REFRESH - 1 ))
done
