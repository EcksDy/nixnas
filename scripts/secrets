#!/usr/bin/env bash
# Manage sops-encrypted secrets without installing sops/age on the host.
# Runs sops+age from the nixos/nix Docker image, using your personal key.
#
# Usage:
#   scripts/secrets edit-plain   # open plaintext secrets/arr.yaml in $EDITOR (nano)
#   scripts/secrets encrypt      # encrypt secrets/arr.yaml IN PLACE (do before commit!)
#   scripts/secrets edit         # edit an already-ENCRYPTED secrets/arr.yaml
#   scripts/secrets decrypt-view # print decrypted content (never writes)
#
# Your personal age key must be at .keys/personal-age.key (gitignored).
set -euo pipefail

REPO="$(cd "$(dirname "$0")/.." && pwd)"
IMAGE="nixos/nix:latest"
KEY=".keys/personal-age.key"
FILE="secrets/arr.yaml"
MODE="${1:-edit}"

[ -f "$REPO/$KEY" ] || { echo "missing $KEY (your personal age key)"; exit 1; }

run() {
  docker run --rm -it \
    -v "$REPO":/repo \
    -e SOPS_AGE_KEY_FILE=/repo/"$KEY" \
    -e EDITOR=nano \
    -w /repo "$IMAGE" sh -c "
      export NIX_CONFIG='experimental-features = nix-command flakes'
      exec nix shell nixpkgs#sops nixpkgs#age nixpkgs#nano -c $1
    "
}

case "$MODE" in
  edit-plain)   run "nano $FILE" ;;
  encrypt)      run "sops --encrypt --in-place $FILE" && echo "encrypted $FILE (safe to commit)" ;;
  edit)         run "sops $FILE" ;;
  decrypt-view) run "sops --decrypt $FILE" ;;
  *) echo "unknown mode: $MODE"; exit 1 ;;
esac
